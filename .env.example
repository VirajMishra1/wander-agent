# Wander Agent - API Keys
# Copy this file to .env and fill in your keys.
# All APIs below have FREE tiers. No paid keys required.

# === PRIMARY (flights + hotels) ===
# Travelpayouts - signup is free, no approval needed: https://www.travelpayouts.com
# One token covers flights (Aviasales) AND hotels (Hotellook)
TRAVELPAYOUTS_TOKEN=
TRAVELPAYOUTS_MARKER=

# === FLIGHT FALLBACK ===
# Kiwi Tequila - free sandbox tier: https://tequila.kiwi.com
KIWI_API_KEY=

# === ATTRACTIONS / POIs ===
# OpenTripMap - free: https://opentripmap.io
OPENTRIPMAP_API_KEY=

# === PLACE VERIFICATION (anti-hallucination) ===
# Foursquare - 200k/mo free: https://developer.foursquare.com
FOURSQUARE_API_KEY=

# === LOCAL EVENTS DURING TRIP ===
# Ticketmaster Discovery - 5k/day free: https://developer.ticketmaster.com
TICKETMASTER_API_KEY=

# === MAPS / GEOCODING (optional, only if defaults rate-limit) ===
# LocationIQ - 5k/day free: https://locationiq.com
LOCATIONIQ_API_KEY=

# === NO API KEY NEEDED ===
# Open-Meteo (weather + historical)        - free, no auth
# Frankfurter (currency)                    - free, no auth
# REST Countries (country info)             - free, no auth
# Nominatim/OpenStreetMap (geocoding)       - free, no auth
# Travelbriefing.org (travel advisories)    - free, no auth
# Teleport (cost of living, quality scores) - free, no auth
# Xotelo (hotel prices, fallback)           - free, no auth
