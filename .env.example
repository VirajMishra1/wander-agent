# Wander Agent - API Keys
# Copy to .env and fill in your keys.

# === FLIGHTS — NO KEY NEEDED ===
# Flights use fast_flights library (scrapes Google Flights).
# Real flight data, real prices, real airlines. No signup required.
# The inspiration tools loop this over ~40 popular destinations.

# === HOTELS ===
# Hotellook (Travelpayouts) — free signup at https://www.travelpayouts.com
# The only viable free hotel API. Sign up takes 2 min, no approval needed.
# After signup: create a Project, then find API token in Tools/API section.
TRAVELPAYOUTS_TOKEN=
TRAVELPAYOUTS_MARKER=

# === ATTRACTIONS / POIs ===
# OpenTripMap — free at https://opentripmap.io
OPENTRIPMAP_API_KEY=

# === PLACE VERIFICATION (optional, adds confidence) ===
# Foursquare — 200k/mo free at https://developer.foursquare.com
# Optional. Wikidata + Open-Meteo geocoder cover most cases without it.
FOURSQUARE_API_KEY=

# === LOCAL EVENTS ===
# Ticketmaster Discovery — 5k/day free at https://developer.ticketmaster.com
TICKETMASTER_API_KEY=

# === NO API KEY NEEDED ===
# Google Flights (via fast_flights)         - no auth
# Open-Meteo (weather + historical)         - no auth
# Open-Meteo Geocoding                      - no auth
# Frankfurter (currency)                    - no auth
# REST Countries (country info)             - no auth
# US State Department (advisories)          - no auth
# Wikidata SPARQL (place verification)      - no auth
# Curated cost-of-living dataset            - no auth (embedded)
