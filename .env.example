# Wander Agent - API Keys
# Copy to .env and fill in your keys.

# === ZERO KEYS REQUIRED FOR FLIGHTS + HOTELS ===
# Flights: Google Flights via fast_flights library (scrapes).
# Hotels:  Google Hotels names + Booking.com/Airbnb deeplinks + LLM web-search.
# Both work out of the box without any signup.

# === OPTIONAL: Live hotel prices ===
# Travelpayouts Hotellook gives live prices INSIDE the tool response.
# Without this, hotels still work but you click through deeplinks for prices.
# Free signup: https://www.travelpayouts.com (no approval needed but token
# location is buried in their UI - see README troubleshooting)
TRAVELPAYOUTS_TOKEN=
TRAVELPAYOUTS_MARKER=

# === OPTIONAL: Richer attractions data ===
# OpenTripMap — free at https://opentripmap.io
OPENTRIPMAP_API_KEY=

# === OPTIONAL: Place verification confidence ===
# Foursquare — 200k/mo free at https://developer.foursquare.com
# Wikidata + Open-Meteo geocoder cover most cases without it.
FOURSQUARE_API_KEY=

# === OPTIONAL: Concert/event search ===
# Ticketmaster Discovery — 5k/day free at https://developer.ticketmaster.com
TICKETMASTER_API_KEY=

# === NO API KEY NEEDED (built-in) ===
# Google Flights (via fast_flights)         - no auth
# Google Hotels names (via fast_hotels)     - no auth
# Open-Meteo (weather + historical)         - no auth
# Open-Meteo Geocoding                      - no auth
# Frankfurter (currency)                    - no auth
# REST Countries (country info)             - no auth
# US State Department (advisories)          - no auth
# Wikidata SPARQL (place verification)      - no auth
# Curated cost-of-living dataset            - no auth (embedded)
# Booking.com / Google Hotels / Airbnb deeplinks - no auth
